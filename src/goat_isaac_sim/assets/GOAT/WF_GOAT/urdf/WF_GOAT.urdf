<?xml version="1.0" encoding="utf-8"?>
<robot name="wheel_GOAT">
    <!-- 
      Uncomment to support the robot by fixing its base link to the world frame. 
      This anchors the robot in place, preventing movement.
    -->
    
    <!-- 
    <link name="world"/>
    <joint name="base_static_Joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0.3"/>
        <parent link="world"/>
        <child link="base_Link"/>
    </joint>
    -->
    <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
    </material>
    <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
    </material>
    <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
    </material>
    <material name="grey">
        <color rgba="0.2 0.2 0.2 1.0"/>
    </material>
    <material name="silver">
        <color rgba="0.9137254901960784 0.9137254901960784 0.8470588235294118 1.0"/>
    </material>
    <material name="orange">
        <color rgba="1.0 0.4235294117647059 0.0392156862745098 1.0"/>
    </material>
    <material name="brown">
        <color rgba="0.8705882352941177 0.8117647058823529 0.7647058823529411 1.0"/>
    </material>
    <material name="red">
        <color rgba="0.8 0.0 0.0 1.0"/>
    </material>
    <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
    </material>

    <!-- ****************************************** Link ******************************************************** -->

    <link name="base_Link">
        <inertial>
            <origin rpy="0 0 0" xyz="-9.521E-03 0.016E-03 -72.346E-03"/>
            <mass value="2.818"/>
            <inertia ixx="20284.45E-06" ixy="-5.647E-06" ixz="6404.633E-06"
                    iyy="23476.973E-06" iyz="0.541E-06" izz="21206.204E-06"/>
